---
// 客房總覽 — 繁體中文版
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BookingCTA from '../../../components/BookingCTA.astro';
import { ROOMS } from '../../../lib/constants';
import { buildGraph, lodgingBusinessSchema, breadcrumbSchema } from '../../../lib/jsonld';

const graph = buildGraph(
  lodgingBusinessSchema(),
  breadcrumbSchema([
    { name: '首頁', url: 'https://guide.washinmura.jp/zh-tw/' },
    { name: '客房', url: 'https://guide.washinmura.jp/zh-tw/rooms/' },
  ]),
);
---
<BaseLayout
  title="客房一覽 — 和心村 Washin Village"
  description="和心村 4 種特色客房：築 200 年古民家、隈研吾×Snow Peak 住箱、長屋門、Nordisk 豪華帳篷。每晚 ¥18,000 起。東京出發 80 分鐘。"
  lang="zh-Hant"
  path="/zh-tw/rooms/"
  jaPath="/rooms/"
  enPath="/en/rooms/"
  jsonLd={graph}
>

<h1>客房一覽 — 4 種特色住宿體驗</h1>
<p>從築 200 年的古民家到世界級建築師設計的行動住宅 — 找到最適合你旅行風格的一間。</p>

<table>
  <thead>
    <tr><th>客房名稱</th><th>類型</th><th>容納人數</th><th>面積</th><th>每晚價格</th></tr>
  </thead>
  <tbody>
    {ROOMS.map(room => (
      <tr>
        <td><a href={`/zh-tw/rooms/${room.id}/`}>{room.nameEn}</a></td>
        <td>{room.typeEn}</td>
        <td>{room.maxOccupancy} 人</td>
        <td>{room.area}m²</td>
        <td>¥{room.priceFrom.toLocaleString()} 起</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>怎麼選客房？</h2>
<table>
  <thead><tr><th>你想要的體驗</th><th>推薦客房</th></tr></thead>
  <tbody>
    <tr><td>正統日本古民家 + 和貓咪共處</td><td>古民家主屋（Kominka）</td></tr>
    <tr><td>設計感十足的兩人浪漫之旅</td><td>住箱（隈研吾 × Snow Peak）</td></tr>
    <tr><td>多人家庭或好友出遊（最多 6 人）</td><td>長屋門（Nagayamon）</td></tr>
    <tr><td>享受星空下的戶外露營感</td><td>Nordisk 豪華帳篷</td></tr>
  </tbody>
</table>

<h2>所有客房皆包含</h2>
<ul>
  <li>免費專用停車位</li>
  <li>WiFi 無線網路</li>
  <li>芬蘭式柴火三溫暖（免費使用）</li>
  <li>BBQ 烤肉套餐（千葉在地食材）</li>
  <li>與 16 隻保護貓自由互動</li>
</ul>

<BookingCTA />
</BaseLayout>
