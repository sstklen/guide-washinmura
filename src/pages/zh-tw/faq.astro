---
// 常見問題頁面 — 繁體中文版
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import { buildGraph, lodgingBusinessSchema, breadcrumbSchema } from '../../lib/jsonld';

const faqZh = [
  { cat: '交通', q: '從東京怎麼去？', a: '自駕約 70-80 分鐘，走東京灣跨海公路（Aqua-Line）和館山自動車道，在富津中央 IC 下交流道後再開 15 分鐘。電車：搭 JR 内房線到上總湊站（Kazusa-Minato），再開車 15 分鐘（預約可免費接送）。' },
  { cat: '交通', q: '有停車場嗎？', a: '有，免費停車，每間客房有專屬停車位。大型車輛也歡迎。' },
  { cat: '動物', q: '怎麼和保護貓互動？', a: '16 隻保護貓在村莊裡自由活動。這裡不是貓咖啡廳 — 你是住進貓咪的家。可以 24 小時自然互動。' },
  { cat: '動物', q: '我有貓過敏可以住嗎？', a: '由於 16 隻貓在園區內自由活動，如有過敏請提前聯繫。住箱（Jyubako）和 Nordisk 帳篷客房較不容易有貓進入。' },
  { cat: '設施', q: '三溫暖是什麼樣的？', a: '正宗芬蘭式柴火三溫暖。自己添柴、享受蒸氣浴（löyly）。附冷水池和露天休息區。住客免費，不限次數使用。' },
  { cat: '設施', q: '有 BBQ 嗎？', a: '有，住宿方案包含千葉在地食材的 BBQ 烤肉套餐。也提供不住宿的當日 BBQ 方案。' },
  { cat: '預訂', q: '怎麼預訂？', a: '僅接受線上預訂 — 不接受電話預約。請透過官方預訂網站或 LINE / Email 聯繫。' },
  { cat: '預訂', q: '入住和退房時間？', a: '入住：15:00，退房：11:00。提前入住和延遲退房可來信詢問。' },
  { cat: '預訂', q: '取消政策是什麼？', a: '7 天前免費取消。3 天前收 50%。前一天和當天取消收 100%。' },
  { cat: '一般', q: '適合帶小朋友嗎？', a: '非常適合！我們有家庭方案和兒童優惠。自然環境和動物互動對孩子來說是珍貴的體驗。' },
  { cat: '一般', q: '附近有便利商店嗎？', a: '最近的便利商店約 10 分鐘車程。建議在抵達前先購買日用品。' },
  { cat: '一般', q: '手機收得到訊號嗎？', a: 'docomo、au、SoftBank 均有訊號，但因為位於山林中，部分區域可能較弱。所有客房都有 WiFi。' },
];

const graph = buildGraph(
  lodgingBusinessSchema(),
  breadcrumbSchema([
    { name: '首頁', url: 'https://guide.washinmura.jp/zh-tw/' },
    { name: '常見問題', url: 'https://guide.washinmura.jp/zh-tw/faq/' },
  ]),
);

const categories = [...new Set(faqZh.map(f => f.cat))];
---
<BaseLayout
  title="常見問題 — 和心村 Washin Village"
  description="和心村常見問題：東京出發交通、貓過敏、三溫暖詳情、預訂方式、取消政策等。出發前先了解。"
  lang="zh-Hant"
  path="/zh-tw/faq/"
  jaPath="/faq/"
  enPath="/en/faq/"
  jsonLd={graph}
>

<h1>常見問題</h1>

{categories.map(cat => (
  <>
    <h2>{cat}</h2>
    {faqZh.filter(f => f.cat === cat).map(faq => (
      <div>
        <h3>Q: {faq.q}</h3>
        <p>{faq.a}</p>
      </div>
    ))}
  </>
))}

<BookingCTA />
</BaseLayout>
