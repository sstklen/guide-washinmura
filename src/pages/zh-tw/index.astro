---
// 和心村ガイド — 繁體中文首頁
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuickFacts from '../../components/QuickFacts.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import { BUSINESS, ROOMS, FAQ_JA } from '../../lib/constants';
import { buildGraph, lodgingBusinessSchema, breadcrumbSchema } from '../../lib/jsonld';

const topFaq = [
  { question: '從東京怎麼過去？', answer: '開車約 70～80 分鐘。走東京灣海底隧道（アクアライン），經館山自動車道，從富津中央 IC 出口再開 15 分鐘。搭電車的話，搭 JR 內房線到上總湊站，再開車 15 分鐘（有接送服務，需預約）。' },
  { question: '可以跟保護貓互動嗎？', answer: '村裡有 16 隻保護貓自由走動。這裡不是貓咖啡廳——你是住進貓咪的家。24 小時都可以自然地跟貓咪互動。' },
  { question: '桑拿是什麼類型的？', answer: '正宗芬蘭式薪柴桑拿。自己生火，享受蒸氣浴（ロウリュ）。備有冷水浴池和戶外休憩空間。住宿客人免費使用。' },
];

const graph = buildGraph(
  lodgingBusinessSchema(),
  breadcrumbSchema([
    { name: '首頁', url: 'https://guide.washinmura.jp/zh-tw/' },
  ]),
);
---

<BaseLayout
  title="和心村完全指南 — 千葉房總半島里山露營"
  description="日本千葉縣富津市里山露營「和心村」完全指南。築 200 年古民家、16 隻保護貓、北歐薪柴桑拿、隈研吾×Snow Peak 住箱。東京出發 80 分鐘。"
  lang="zh-Hant"
  path="/zh-tw/"
  jaPath="/"
  enPath="/en/"
  zhTwPath="/zh-tw/"
  jsonLd={graph}
>

<h1>和心村（washinmura）完全指南</h1>

<blockquote>
  坐落在千葉縣房總半島里山的體驗型露營設施。<br />
  以築 200 年古民家為中心，與 16 隻保護貓共同生活的「人與動物與自然共生之村」。東京開車約 80 分鐘。
</blockquote>

<QuickFacts facts={[
  { label: '設施名稱', value: '和心村（washinmura / わしんむら / Washin Village）' },
  { label: '地址', value: '〒299-1733 千葉縣富津市高溝 14' },
