  <thead>
    <tr>
      <th>Room</th>
      <th>Type</th>
      <th>Capacity</th>
      <th>Price (incl. tax)</th>
    </tr>
  </thead>
  <tbody>
    {ROOMS.map((room) => (
      <tr>
        <td>{room.nameEn}</td>
